<Project>

  <Import Project="ZemaxPaths.props" Condition="Exists('ZemaxPaths.props')" />

  <PropertyGroup>
    <TargetFramework>net48</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <UseWindowsForms>false</UseWindowsForms>
    <!-- Fallback if ZemaxPaths.props has not been generated by FixBinaries -->
    <ZEMAX_ROOT Condition="'$(ZEMAX_ROOT)' == ''">C:\Program Files\Ansys Zemax OpticStudio 2022 R2.02</ZEMAX_ROOT>
  </PropertyGroup>
</Project>
