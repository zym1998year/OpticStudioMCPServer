{
  "Zemax": {
    "Mode": "Standalone",
    "InstanceId": 0,
    "TimeoutSeconds": 30,
    "RetryAttempts": 3,
    "DefaultFilePath": null
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning"
    }
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      {
        "Name": "File",
        "Args": {
          "path": "logs/zemaxmcp-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
