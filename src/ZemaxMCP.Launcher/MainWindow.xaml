<Window x:Class="ZemaxMCP.Launcher.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="Zemax MCP Setup" Width="720" Height="540" WindowStartupLocation="CenterScreen" Loaded="OnLoaded">
  <Grid Margin="20"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <TextBlock Text="Zemax MCP — setup and LAN bridge" FontSize="22" FontWeight="SemiBold"/>
    <StackPanel Grid.Row="1" Margin="0,16,0,0"><TextBlock Text="Detected OpticStudio installations" FontWeight="SemiBold"/><ComboBox x:Name="ZemaxVersions" DisplayMemberPath="DisplayName" SelectionChanged="ZemaxVersions_SelectionChanged" Margin="0,6,0,0"/></StackPanel>
    <Grid Grid.Row="2" Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="120"/></Grid.ColumnDefinitions><CheckBox x:Name="ShareOnLan" Content="Share with a trusted LAN computer" Checked="ShareOnLan_Changed" Unchecked="ShareOnLan_Changed"/><TextBox x:Name="Port" Grid.Column="1" Text="8000" Margin="8,0,0,0"/></Grid>
    <StackPanel Grid.Row="3" Margin="0,6,0,0"><TextBlock x:Name="Endpoint" Foreground="DimGray"/><TextBlock Text="Remote MCP URL (optional, for a second computer):" Margin="0,8,0,0" Foreground="DimGray"/><TextBox x:Name="RemoteEndpoint" Margin="0,3,0,0" ToolTip="Paste the endpoint copied from the OpticStudio computer"/></StackPanel>
    <WrapPanel Grid.Row="4" Margin="0,16,0,0"><Button Content="Start HTTP MCP" Padding="12,6" Margin="0,0,8,8" Click="Start_Click"/><Button Content="Stop" Padding="12,6" Margin="0,0,8,8" Click="Stop_Click"/><Button Content="Test MCP connection" Padding="12,6" Margin="0,0,8,8" Click="TestMcp_Click"/><Button Content="Configure installed AI clients" Padding="12,6" Margin="0,0,8,8" Click="ConfigureDetected_Click"/><Button Content="Copy MCP address" Padding="12,6" Margin="0,0,8,8" Click="CopyEndpoint_Click"/><Button Content="Open logs" Padding="12,6" Margin="0,0,8,8" Click="OpenLogs_Click"/><Button Content="Configure Codex" Padding="12,6" Margin="0,0,8,8" Click="Codex_Click"/><Button Content="Configure Claude" Padding="12,6" Margin="0,0,8,8" Click="Claude_Click"/><Button Content="Configure Cursor" Padding="12,6" Margin="0,0,8,8" Click="Cursor_Click"/><Button Content="Check updates" Padding="12,6" Margin="0,0,8,8" Click="Update_Click"/></WrapPanel>
    <TextBox Grid.Row="5" x:Name="Status" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0"/>
    <TextBlock Grid.Row="6" Text="The bridge writes logs beside the installed application. Use a private LAN and firewall rules when listening beyond localhost." Foreground="DimGray" TextWrapping="Wrap" Margin="0,12,0,0"/>
  </Grid>
</Window>
